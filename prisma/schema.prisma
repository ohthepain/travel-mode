// travelmode — Better Auth + flight tracks
// https://www.prisma.io/docs/orm

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Better Auth — table name `user`
model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  savedFlights  UserSavedFlight[]

  @@unique([email])
  @@map("user")
}

/// Flights the signed-in user saved from search (for “My flights”).
model UserSavedFlight {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flightNumber       String
  /// Calendar date in UTC (time component ignored), same as Track.travelDate
  travelDate         DateTime  @db.Date
  fr24FlightId       String?
  originIata         String?
  destIata           String?
  scheduledDeparture DateTime?
  scheduledArrival   DateTime?
  takeoffAt          DateTime?
  createdAt          DateTime  @default(now())

  @@unique([userId, flightNumber, travelDate])
  @@index([userId])
  @@map("user_saved_flight")
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session")
}

model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

/// One stored track per FR24 flight id (historical)
model Track {
  id              String   @id @default(cuid())
  /// IATA-style e.g. UA123
  flightNumber    String
  /// Calendar date in UTC (time component ignored)
  travelDate      DateTime @db.Date
  /// FR24 flight id from summary
  fr24FlightId    String   @unique
  routeGeojson    Json
  corridorGeojson Json?
  /// [minLon, minLat, maxLon, maxLat] in WGS84
  bbox            Json?
  /// First / last point epoch ms from track (for interpolation; BIGINT — ms exceeds 32-bit int)
  firstTimestampMs BigInt?
  lastTimestampMs  BigInt?
  rawSummaryJson  Json?
  /// IATA (from flight-summary full, when present)
  originIata      String?
  destIata        String?
  originIcao      String?
  destIcao        String?
  takeoffAt       DateTime?
  landedAt        DateTime?
  scheduledDeparture DateTime?
  scheduledArrival   DateTime?
  /// Takeoff-to-landing duration (seconds) when provided by API
  flightTimeSec   Int?
  /// Extra fields from full summary (runway, reg, etc.)
  scheduleJson    Json?
  fetchedAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([flightNumber, travelDate])
  @@map("track")
}

// --- AirLabs reference + schedule cache (on-demand) ---

model AirlabsAirport {
  iataCode    String   @id
  icaoCode    String?
  name        String
  cityCode    String
  countryCode String
  lat         Float
  lon         Float
  rawJson     Json?
  fetchedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("airlabs_airport")
}

model AirlabsAirline {
  iataCode     String   @id
  icaoCode     String?
  name         String
  countryCode  String
  rawJson      Json?
  fetchedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("airlabs_airline")
}

model AirlabsCity {
  cityCode    String   @id
  name        String
  countryCode String
  lat         Float
  lon         Float
  rawJson     Json?
  fetchedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("airlabs_city")
}

/// Cached `GET /flight-schedule` responses (JSON payload is FlightSchedule[]).
model AirlabsScheduleCache {
  id         String   @id @default(cuid())
  flightIata String
  /// `YYYY-MM-DD` or the literal `nodate` when the client omits `date`.
  dateKey    String
  payload    Json
  fetchedAt  DateTime @default(now())

  @@unique([flightIata, dateKey])
  @@index([fetchedAt])
  @@map("airlabs_schedule_cache")
}
