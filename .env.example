# Local Postgres on 5432 (default). If you use docker-compose in this repo, it maps 5433→5432.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/travelmode"
BETTER_AUTH_SECRET="use-openssl-rand-hex-32"
# App URL for links, cookies, OAuth redirects, and better-auth "trusted origin" (must match the address bar, including port — `pnpm dev` uses 3020).
BETTER_AUTH_URL="http://localhost:3020"
# Comma-separated extra browser origins allowed for CORS and auth (e.g. preview deploys). Must include your real site https origin in production.
TRUSTED_ORIGINS=""
# Optional: when local dev uses http but Google OAuth / cookies are tested via a tunnel, set this to the tunnel https origin.
VITE_PUBLIC_APP_URL=""

# Google OAuth (SSO) — add redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AWS SES — verify a sender identity in SES and use a verified address. If unset, verification/reset/magic emails are only logged in development.
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SES_FROM_EMAIL=""
EMAIL_APP_NAME="travelmode.live"

# If "true", password sign-in requires a verified email (link in inbox) before login.
AUTH_REQUIRE_EMAIL_VERIFICATION="false"
FLIGHTRADAR24_API_TOKEN=""
# AirLabs (schedules, routes, airport/airline/city reference) — used by /api/flight-schedule, /api/airports, /api/airlines, /api/cities
AIRLABS_API_KEY=""
# Optional: cache TTL (seconds) for reference rows and for schedule responses (defaults: 30d ref, 45m schedule)
# AIRLABS_REF_CACHE_TTL_SEC=""
# AIRLABS_SCHEDULE_CACHE_TTL_SEC=""
# Legacy alias: FR24_API_TOKEN
# If 1, skip queuing and skip sync work when a track for that flight number already exists in the summary lookback window (see FR24_FLIGHT_SUMMARY_LOOKBACK_DAYS). May miss additional legs of the same flight number in that window.
SKIP_FR24_IF_SYNCED="0"
ALLOW_MOCK_FR24="0"
# MapTiler: API key for the server tile/style proxies (/api/map-tiles/..., /api/map-style-vector, /api/maptiler-cdn). The server reads process.env first (VITE_MAPTILER_API_KEY, then MAPTILER_API_KEY, then VITE_MAPTILER_KEY), so it matches curl after `source .env`. Prefer a key without HTTP-origin restriction; see docs/offline-maps-and-tiles.md.
VITE_MAPTILER_API_KEY=""
# Optional: preset id (topo-v2, base-v4, …) or your MapTiler Cloud **custom** map id — adds “Custom” to the basemap picker and defaults the app to that map when unset in the UI.
VITE_MAPTILER_RASTER_MAP_ID=""